# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/medtrack

# ── Security ──────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Twilio (SOS Alerts) ───────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# ── App ───────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
ALLOWED_ORIGINS_RAW=http://localhost:8081,exp://192.168.1.x:8081,http://127.0.0.1:8081
